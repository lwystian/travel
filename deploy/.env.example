APP_VERSION=latest
COMPOSE_PROJECT_NAME=travel
TZ=Asia/Shanghai

# Persistent files are created automatically by Docker Compose.
# Default path is relative to the deploy directory.
TRAVEL_DATA_DIR=./travel-data

HTTP_PORT=80
APP_SECURITY_ALLOWED_ORIGINS=https://your-domain.com,http://your-server-ip
APP_SECURITY_PASSWORD_ENCRYPTION_ENABLED=true

MYSQL_DATABASE=tourism_system
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_USER=travel
MYSQL_PASSWORD=change-this-app-password

REDIS_PASSWORD=change-this-redis-password

APP_SUPER_ADMIN_BOOTSTRAP_ENABLED=true
APP_SUPER_ADMIN_USERNAME=superadmin
APP_SUPER_ADMIN_PHONE=18888888888
APP_SUPER_ADMIN_INITIAL_PASSWORD=change-this-admin-password
USER_DEFAULT_PASSWORD=change-this-default-password

JAVA_OPTS=-Xms512m -Xmx1024m
